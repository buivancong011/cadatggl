echo "Dọn dẹp container lỗi..."
docker rm -f myst >/dev/null 2>&1

echo "Khởi tạo lại với Docker Port Forwarding..."
docker run -d \
  --name myst \
  --restart unless-stopped \
  --cap-add NET_ADMIN \
  --log-opt max-size=5m --log-opt max-file=2 --ulimit nofile=1048576:1048576 \
  --dns 1.1.1.1 --dns 1.0.0.1 \
  -p 4449:4449 \
  -p 10000-60000:10000-60000/udp \
  -v myst-data:/var/lib/mysterium-node \
  mysteriumnetwork/myst:latest \
  service --agreed-terms-and-conditions
