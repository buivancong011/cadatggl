#!/bin/bash
set -e

# ==== HÀM HIỂN THỊ LOG ====
log() { echo -e "\e[32m[INFO] $1\e[0m"; }
warn() { echo -e "\e[33m[WAIT] $1\e[0m"; }

# ==========================================
# 1. LẤY LẠI THÔNG SỐ TỪ HỆ THỐNG ĐANG CHẠY
# ==========================================
log "Đang lấy lại thông số mạng từ VPS..."
MAIN_IFACE=$(ip route show default | awk '/default/ {print $5}' | head -n 1)
IP_ALLA=$(/sbin/ip -4 -o addr show scope global noprefixroute $MAIN_IFACE | awk '{gsub(/\/.*/,"",$4); print $4}' | head -n 1)
IP_ALLB=$(/sbin/ip -4 -o addr show scope global dynamic $MAIN_IFACE | awk '{gsub(/\/.*/,"",$4); print $4}' | head -n 1)
DNS_OPTS="--dns 1.1.1.1 --dns 1.0.0.1"

EMAIL_BITPING="nguyenvinhcao123@gmail.com"
PASS_BITPING="nguyenvinhcao123@gmail.com" 

# ==========================================
# 2. XÓA MYSTERIUM CŨ VÀ CẬP NHẬT LUẬT 10MB
# ==========================================
log "Đang xóa các container Mysterium cũ..."
docker rm -f myst1 myst2 >/dev/null 2>&1 || true

warn "Đang chờ 10 giây để Docker giải phóng cổng mạng..."
sleep 10

log "Khởi chạy lại Mysterium với Giáp bảo vệ 10MB..."
docker run -d --network my_network_1 --cap-add NET_ADMIN $DNS_OPTS \
  -p ${IP_ALLA}:4449:4449 \
  --name myst1 -v myst-data1:/var/lib/mysterium-node \
  --log-opt max-size=10m --log-opt max-file=3 \
  --restart unless-stopped mysteriumnetwork/myst:latest service --agreed-terms-and-conditions >/dev/null

docker run -d --network my_network_2 --cap-add NET_ADMIN $DNS_OPTS \
  -p ${IP_ALLB}:4449:4449 \
  --name myst2 -v myst-data2:/var/lib/mysterium-node \
  --log-opt max-size=10m --log-opt max-file=3 \
  --restart unless-stopped mysteriumnetwork/myst:latest service --agreed-terms-and-conditions >/dev/null

# ==========================================
# 3. KÉO IMAGE VÀ CHẠY THÊM BITPING
# ==========================================
log "Đang tải image và dọn dẹp tiến trình Bitping..."
docker pull bitping/bitpingd:latest >/dev/null 2>&1
docker rm -f bitping1 bitping2 >/dev/null 2>&1 || true

log "Khởi chạy Bitping (giới hạn 10MB)..."
docker run -d --network my_network_1 --restart unless-stopped $DNS_OPTS \
  --name bitping1 \
  -v bitping_data1:/root/.bitpingd \
  --log-opt max-size=10m --log-opt max-file=3 \
  -e BITPING_EMAIL="$EMAIL_BITPING" \
  -e BITPING_PASSWORD="$PASS_BITPING" \
  bitping/bitpingd:latest >/dev/null

docker run -d --network my_network_2 --restart unless-stopped $DNS_OPTS \
  --name bitping2 \
  -v bitping_data2:/root/.bitpingd \
  --log-opt max-size=10m --log-opt max-file=3 \
  -e BITPING_EMAIL="$EMAIL_BITPING" \
  -e BITPING_PASSWORD="$PASS_BITPING" \
  bitping/bitpingd:latest >/dev/null

log "==== HOÀN TẤT CẬP NHẬT (MYST + BITPING) ===="
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" | grep -E "myst|bitping|NAMES"
