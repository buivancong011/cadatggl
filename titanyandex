#!/bin/bash
set -e

log() { echo -e "\e[32m[INFO] $1\e[0m"; }
err() { echo -e "\e[31m[ERROR] $1\e[0m"; exit 1; }

# ==========================================
# 1. ĐẾM LẠI IP TRÊN CÁC CARD MẠNG (CHUẨN YANDEX CLOUD)
# ==========================================
log "📡 Đang quét lại toàn bộ IP Private trên các card mạng..."

# Quét tất cả IP thuộc các card có tên bắt đầu bằng 'eth'
mapfile -t ALL_IPS < <(ip -o -4 addr show | grep ' eth' | grep -w inet | awk '{print $4}' | cut -d/ -f1)
TOTAL_IPS=${#ALL_IPS[@]}

if [ "$TOTAL_IPS" -eq 0 ]; then
    err "LỖI: Không tìm thấy IP nào để rải Titan!"
fi

log "🔥 Phát hiện $TOTAL_IPS IP. Chuẩn bị chạy $TOTAL_IPS node Titan..."

# ==========================================
# 2. TẢI VÀ RẢI TITAN VÀO TỪNG CỤM
# ==========================================
log "Đang tải Image Titan mới nhất..."
docker pull nguyenvinhcao123/titanacc3nguyenvinhcao123:latest >/dev/null 2>&1

for i in "${!ALL_IPS[@]}"; do
    INDEX=$((i+1))
    NET="my_network_$INDEX"
    NAME="titan$INDEX"

    log " -> Dọn dẹp và khởi chạy $NAME trên mạng $NET..."
    docker rm -f $NAME >/dev/null 2>&1 || true

    docker run -d \
      --name $NAME \
      --network $NET \
      --cap-add=SYS_ADMIN \
      --dns 1.1.1.1 --dns 1.0.0.1 \
      --restart always \
      --memory="150m" \
      --cpus="0.3" \
      --log-opt max-size=1m \
      --log-opt max-file=2 \
      nguyenvinhcao123/titanacc3nguyenvinhcao123:latest >/dev/null
done

echo "------------------------------------------------------"
log "==== HOÀN TẤT THÊM $TOTAL_IPS TITAN NODE CHO HỆ THỐNG YANDEX ===="
docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" | grep titan
